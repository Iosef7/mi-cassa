generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("AGENT") // ADMIN, AGENT, MARKETING
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads        Lead[]
  tasks        Task[]
  appointments Appointment[]
}

model Property {
  id              String   @id @default(cuid())
  title           String
  description     String?
  price           Decimal // Precio base o inicial
  minPrice        Decimal?
  maxPrice        Decimal?
  type            String // CASA, DEPARTAMENTO, TERRENO, LOCAL, PROYECTO
  status          String   @default("DISPONIBLE") // DISPONIBLE, RESERVADA, VENDIDA, PAUSADA
  location        String
  bedrooms        Int?
  bathrooms       Int?
  area            Float?
  availableUnits  Int?
  deliveryDate    String? // Ej: "Q3 2025", "Inmediata"
  images          String? // JSON stringified array of URLs
  presentations   String? // JSON stringified array of URLs
  nearbyPlaces    String? // JSON stringified array of objects
  dynamicFeatures String? // JSON stringified object of property specific features
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ownerName  String?
  ownerPhone String?
  ownerEmail String?
  ownerNotes String?

  leads Lead[]
}

model Lead {
  id     String   @id @default(cuid())
  name   String
  email  String?
  phone  String
  status String   @default("NUEVO") // NUEVO, CONTACTADO, VISITA_AGENDADA, NEGOCIACION, FIRMA, CERRADO_GANADO
  budget Decimal?
  notes  String?
  source String? // e.g. "Meta Ads", "Organic"

  preferences      String? // JSON stringified de preferencias
  requiresMortgage Boolean @default(false)

  agentId String?
  agent   User?   @relation(fields: [agentId], references: [id])

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])

  calls        Call[]
  tasks        Task[]
  appointments Appointment[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id     String   @id @default(cuid())
  title  String
  date   DateTime
  status String   @default("PENDIENTE") // PENDIENTE, CONFIRMADA, CANCELADA, REALIZADA

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  agentId String?
  agent   User?   @relation(fields: [agentId], references: [id])

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id      String  @id @default(cuid())
  content String
  fromBot Boolean @default(false)

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Call {
  id            String   @id @default(cuid())
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id])
  duration      Int // in seconds
  audioUrl      String?
  transcription String?
  summary       String?
  mainTopic     String?
  keyPoints     String? // JSON stringified array
  commitments   String? // JSON stringified array
  sentiment     String? // Positivo, Neutro, Negativo
  createdAt     DateTime @default(now())
}

model TaskList {
  id        String   @id @default(cuid())
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("PENDIENTE") // PENDIENTE, EN_PROGRESO, COMPLETADO
  isImportant Boolean   @default(false)
  dueDate     DateTime?

  assignedTo String?
  agent      User?   @relation(fields: [assignedTo], references: [id])

  listId String?
  list   TaskList? @relation(fields: [listId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- CMS Models ---

model Page {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  isPublished Boolean   @default(false)
  metaTitle   String?
  metaDesc    String?
  sections    Section[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Section {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String // Ej: "HERO", "FEATURES", "TESTIMONIALS", "TEXT_IMAGE"
  order     Int      @default(0)
  content   String // JSON stringified (textos, imagenes, colores)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique // Ej: "logo", "primaryColor", "contactEmail"
  value     String // El valor (puede ser JSON)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiUsage {
  id               String   @id @default(cuid())
  provider         String // Ej: "Google", "OpenAI", "Anthropic"
  model            String // Ej: "gemini-1.5-flash", "gpt-4o"
  operationType    String // Ej: "CallSummary", "PropertyDescription"
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  costUSD          Float    @default(0.0)
  status           String   @default("SUCCESS") // SUCCESS, ERROR
  errorMessage     String?
  createdAt        DateTime @default(now())
}
